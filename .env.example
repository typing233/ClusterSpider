# Neo4j
CS_NEO4J_URI=bolt://localhost:7687
CS_NEO4J_USER=neo4j
CS_NEO4J_PASSWORD=changeme

# Redis
CS_REDIS_URL=redis://localhost:6379/0
CS_CELERY_BROKER_URL=redis://localhost:6379/1
CS_CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
CS_JWT_SECRET=change-this-to-a-random-secret-in-production
CS_ACCESS_TOKEN_EXPIRE_MINUTES=30
CS_REFRESH_TOKEN_EXPIRE_DAYS=7

# Third-party API keys
CS_HIBP_API_KEY=
CS_GITHUB_TOKEN=
CS_IPINFO_TOKEN=

# Encryption key for stored API keys (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
CS_FERNET_KEY=

# Server
CS_API_HOST=0.0.0.0
CS_API_PORT=8000
CS_CORS_ORIGINS=http://localhost:3000
